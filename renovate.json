{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "prHourlyLimit": 0,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^pom\\.xml$/"],
      "matchStrings": ["<(?<depName>[a-z][a-z0-9-]+)\\.version>(?<currentValue>[^$<][^<]*)<"],
      "datasourceTemplate": "jenkins-plugins"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["jenkins-plugins"],
      "minimumReleaseAge": "0 seconds",
      "ignoreUnstable": false,
      "recreateWhen": "always"
    },
    {
      "matchDatasources": ["maven"],
      "matchPackagePrefixes": ["org.jenkins-ci.plugins:"],
      "registryUrls": ["https://repo.jenkins-ci.org/releases/"],
      "enabled": false
    }
  ]
}
